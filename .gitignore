# Windows shell metadata
desktop.ini
**/desktop.ini

# Python bytecode / cache
__pycache__/
*.pyc

# Temporary working files (root-level _tmp_*.py / _tmp_pdf_pages/ 等)
_tmp_*

# Machine-local logs (night-batch, headless test)
logs/

# Local archives (legacy outputs, debug payloads)
_archive/

# HTML 成果物も git 管理する（2026-06-05 方針変更）。
# 旧運用は outputs/**/*.html を除外し Drive 管理だったが、
# リモート実行環境（ephemeral）で生成 HTML が失われる事故が頻発。
# Drive MCP のインライン create_file は 250KB 級 HTML を転送できず自動保存が破綻したため、
# 生成＝コミットで GitHub に永続化する方式へ統一した（CLAUDE.md §9）。
# canonical/ は従来どおり構造参考実装として git 管理を継続。

# TTS 音声生成の入出力（台本 txt・生成 wav はローカル管理。コードのみ git）
tts/output_audio/
tts/input_texts/

# API キー等のローカル機密（絶対に git に載せない）。
# パイプラインは .secrets/gemini_main.key / gemini_sub.key から鍵を自動読込する。
.secrets/
*.key

# Drive 配置ミラー（repo 内・H: と同階層）。フォルダ構造のみ git 管理（.gitkeep）、
# 実成果物（html/txt/wav の配置コピー）はローカル扱い（原本は outputs/ 側で git 管理）。
deploy/**/*.html
deploy/**/*.txt
deploy/**/*.wav

# JX 逐語↔PDF 照合補助（scripts/jx-match-transcripts.py）の作業生成物。
# OCR キャッシュと照合提案は再生成可能なため git 管理しない（正典は逐語-PDF対応表.md）。
inputs/jx/*/_ocr_cache/
inputs/jx/*/_match-proposal.md

# AI Studio TTS タブ準備ツール（tools/TTS-tool）の失敗スクショ。
# prep_tts_tabs.py が UI 不一致時に出力する fail_*.png は再現可能なため git 管理しない。
fail_*.png
tools/**/fail_*.png
