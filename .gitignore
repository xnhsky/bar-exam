# Windows shell metadata
desktop.ini
**/desktop.ini

# Python bytecode / cache
__pycache__/
*.pyc

# Temporary working files (root-level _tmp_*.py / _tmp_pdf_pages/ 等)
_tmp_*

# Machine-local logs (night-batch, headless test)
logs/

# Local archives (legacy outputs, debug payloads)
_archive/

# HTML 成果物は Google Drive で管理（git は code/spec のみ）
outputs/**/*.html
# canonical/ は構造参考実装として git 管理を継続
!canonical/**/*.html
