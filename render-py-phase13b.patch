+def inject_v94_footer_hidden(rendered_html: str) -> str:
+    """v9.4.0 専用: footer-spec の visible feature-tag 行を hidden 化する（Phase 13B）。
+
+    validate-tx.py が要求する feature-tag は HTML 内に存在する必要があるが、
+    視覚的には不要（footer がノイズ化する）ため、`<p class="footer-meta">` を
+    `<p class="footer-meta footer-meta-hidden" hidden>` に置換する。
+    `hidden` グローバル属性で要素全体が非表示になり、内側の各 <span class="feature-tag">
+    は HTML 上は parser に到達可能（validate-tx.py の grep/parse は通る）。
+
+    spec_version!="v9.4.0" では呼ばれないため既存 byte-identical 完全維持。
+    """
+    return rendered_html.replace(
+        '<p class="footer-meta">',
+        '<p class="footer-meta footer-meta-hidden" hidden>',
+        1,
+    )
