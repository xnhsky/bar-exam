#!/usr/bin/env bash
# =============================================================================
# pre-commit フック — コミット経路に依存しない (1) 作成日時スタンプ (2) 自動検証 の保険。
#
# (1) スタンプ：どんな経路（jx-push.sh / jx-finalize.ps1 / 素の git commit）でも、
#     ステージ済み Lexia 取込 HTML に lexia-genmeta が無ければ現在時刻(JST)で刻み再ステージ
#     （scripts/stamp-staged.py）。「スタンプ無し HTML が push される」事故を構造的に防ぐ。
# (2) 自動検証：ステージ済み Lexia HTML を種別 validator で自動チェック
#     （scripts/validate-staged.py）。検証を手で叩かなくても commit のたびに自動で走る。
#     既定は report（結果表示のみ・commit は止めない）。ゲート化は環境変数 LEXIA_VALIDATE=block。
#     off で無効。フック自身の不具合では commit を止めない（fail-open）。
#
# 有効化（各 PC で一度だけ）: scripts/install-hooks.sh を実行（core.hooksPath を設定）。
# =============================================================================
set -uo pipefail
ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
py="$(command -v python3 || command -v python)" || exit 0
"$py" "$ROOT/scripts/stamp-staged.py" || true
"$py" -X utf8 "$ROOT/scripts/validate-staged.py"; vc=$?
if [ "${vc:-0}" -ne 0 ]; then exit "$vc"; fi
exit 0
