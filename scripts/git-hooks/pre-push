#!/usr/bin/env bash
# Start a background local sync after pushes to origin/master.
#
# Git has no post-push hook. This hook launches a detached PowerShell helper
# before the push; the helper waits until origin/master contains the commit that
# is being pushed, so failed pushes do not update the target folder.
set -uo pipefail

ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
TARGET="${BAREXAM_CODEX_ROOT:-C:/Users/xnrg2.DESKTOP-5664QR6/bar-exam-codex}"
SCRIPT="$ROOT/scripts/sync-repo-from-master.ps1"
LAUNCHER="$ROOT/scripts/start-repo-sync.ps1"

powershell_bin="$(command -v powershell.exe || command -v powershell || true)"
if [[ -z "$powershell_bin" || ! -f "$SCRIPT" || ! -f "$LAUNCHER" ]]; then
  exit 0
fi

while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$remote_ref" == "refs/heads/master" && "$local_sha" != "0000000000000000000000000000000000000000" ]]; then
    "$powershell_bin" -NoProfile -ExecutionPolicy Bypass \
      -File "$LAUNCHER" \
      -SyncScript "$SCRIPT" \
      -ProjectRoot "$TARGET" \
      -Remote origin \
      -Branch master \
      -WaitForSha "$local_sha" \
      -TimeoutSec 240 >/dev/null 2>&1 || true
  fi
done

exit 0
